# Express server
PORT=5000
MONGODB_URI=mongodb://localhost:27018/fantasyfootball
JWT_SECRET=change-me-in-production
ENCRYPTION_KEY=32-char-hex-key-for-credentials!!
INTERNAL_SERVICE_KEY=change-me-internal-agent-key

# Python MCP server + cron agents
API_URL=http://localhost:5000
WEEKLY_AGENT_CRON=0 14 * * 2
NEWS_WATCH_INTERVAL_MINUTES=60

# OpenAI-compatible LLM for roster agent synthesis (optional)
# For Anthropic Haiku, use your sk-ant-... key here or in ANTHROPIC_API_KEY
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_MODEL=claude-haiku-4-5-20251001
OPENAI_BASE_URL=https://api.anthropic.com/v1
# Set to 0 to disable LLM even when API key is present
ROSTER_AGENT_LLM=1

EXPO_ACCESS_TOKEN=

# OAuth (Yahoo "Sign in" flow) — create an app at https://developer.yahoo.com/apps/
# Redirect URI must be: ${API_PUBLIC_URL}/api/connections/yahoo/oauth/callback
API_PUBLIC_URL=http://localhost:5000
APP_WEB_URL=http://localhost:8081
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
